# Copy this file to ".env" and adjust as needed.
# Expo automatically inlines any var prefixed with EXPO_PUBLIC_ at build time.

# Default: talk to the deployed droplet directly (works from any phone, any network)
EXPO_PUBLIC_API_URL=https://cop4331-9.com/api

# If you want the phone to hit a backend running locally on your Windows machine instead,
# use your computer's LAN IP (NOT localhost/127.0.0.1 -- the phone can't resolve that to your PC).
# Find it on Windows with: ipconfig  (look for "IPv4 Address" under your Wi-Fi adapter)
# EXPO_PUBLIC_API_URL=http://192.168.1.23:5000/api
